{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PixelCatCalendar",
  "version": "0.1.9",
  "identifier": "com.pixelcat.calendar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "label": "main",
        "title": "pixel-cat-calendar",
        "width": 150,
        "height": 150,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": false,
        "fullscreen": false,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": {
        "NSCalendarUsageDescription": "일정 알람을 제공하기 위해 캘린더 데이터를 읽습니다.",
        "NSCalendarsFullAccessUsageDescription": "일정 알람을 제공하기 위해 캘린더 데이터를 읽습니다."
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
